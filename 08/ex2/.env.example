# .env.example — configuration TEMPLATE for oracle.py
#
# This file IS committed to git: it documents which variables the program
# needs, using fake placeholder values. Real secrets never go here.
#
# Setup:
#   cp .env.example .env      # create your personal copy
#   vim .env                  # fill in the real values
#
# The real .env is listed in .gitignore and must NEVER be committed.

# Execution mode: "development" or "production"
# development → verbose output, masked secrets shown with their source
# production  → secrets fully hidden, minimal status output
MATRIX_MODE=development

# Connection string for data storage
# format: dialect://user:password@host:port/database
DATABASE_URL=postgresql://neo:changeme@localhost:5432/matrix

# Secret key for external services — REPLACE with your real key in .env
API_KEY=your-api-key-here

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# URL for the resistance network
ZION_ENDPOINT=https://zion.local:8080
